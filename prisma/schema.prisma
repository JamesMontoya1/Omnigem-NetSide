generator client {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
  
enum Role {
  ADMIN
  GUEST
  TRAVELER
  SPED_MANAGER
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String?
  roles     Role[]   @default([GUEST])
  name      String?
  createdAt DateTime @default(now())
}

model Worker {
  id              Int       @id @default(autoincrement())
  name            String
  color           String?
  active          Boolean   @default(true)
  doesShifts      Boolean   @default(false) // Faz plantões?
  doesTravel      Boolean   @default(false) // Faz viagens?
  hireDate        DateTime?
  terminationDate DateTime?
  createdAt       DateTime  @default(now())

  recurringPatterns RecurringPattern[]
  assignments       Assignment[]
  vacations         Vacation[]
  trips             Trip[]    @relation("TravelerTrip")
  drivenTrips       Trip[]    @relation("DriverTrip")
  vehicleExpenses    VehicleExpense[]
}

model Holiday {
  id        Int      @id @default(autoincrement())
  date      DateTime
  name      String?
  recurring Boolean  @default(false)
  createdAt DateTime @default(now())
}

model RecurringPattern {
  id         Int      @id @default(autoincrement())
  workerId   Int
  worker     Worker   @relation(fields: [workerId], references: [id])
  weekdays   Int[]    // 0=domingo .. 6=sábado
  weekInterval Int    @default(1)
  weekOffset   Int    @default(0)
  startDate  DateTime?
  endDate    DateTime?
  note       String?
  createdAt  DateTime @default(now())
}

model Assignment {
  id         Int      @id @default(autoincrement())
  date       DateTime
  workerId   Int?
  worker     Worker?  @relation(fields: [workerId], references: [id])
  source     AssignmentSource @default(MANUAL)
  note       String?
  createdAt  DateTime @default(now())

  @@unique([date, workerId])
}

enum AssignmentSource {
  MANUAL
  RECURRENT
}

model Rotation {
  id              Int       @id @default(autoincrement())
  name            String?
  weekdays        Int[]     // 0=domingo .. 6=sábado
  workerIds       Int[]     // IDs dos trabalhadores na ordem do rodízio
  startDate       DateTime  // data de início (usada como âncora para calcular a semana)
  endDate         DateTime? // data de finalização (se o rodízio foi substituído)
  notifyUpcoming  Boolean   @default(false) // destaca células em vermelho quando faltam ≤7 dias
  createdAt       DateTime  @default(now())
}

// Lançamentos de férias
model Vacation {
  id        Int      @id @default(autoincrement())
  workerId  Int
  worker    Worker   @relation(fields: [workerId], references: [id])
  startDate DateTime // Data de início das férias
  endDate   DateTime // Data final das férias
  daysUsed  Int      // Dias usados (máx 30 por período aquisitivo)
  sold      Boolean  @default(false) // Vendeu férias?
  active    Boolean  @default(true)  // Lançamento ativo?
  note      String?  // Observações
  createdAt DateTime @default(now())
}

model Sped {
  id               Int       @id @default(autoincrement())
  company          String
  note             String?
  bankAccountStatus Int    // 0 - Aguardando retorno; 1 - Não solicitado; 2 - Configurados; 3 - Aguardando Configurar
  accountingSheetStatus Int?  // 0 - Aguardando retorno; 1 - Não solicitado; 2 - Configurados; 3 - Aguardando Configurar
  icmsIpi          Boolean?
  pisCofins        Boolean?
  regime           Int?    // 0 - PRESUMIDO (Cumulativo); 1 - REAL (Não Cumulativo)
  contactAttempts  Int?    // 0 - Registrando Notas; 1 - Em Contato; 2 - Não Gera; 3 - Feito/Concluído
  lastSent         DateTime?
  reference        String?
  sendingEmails    String[]
  accessContact    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ServiceType {
  id          Int      @id @default(autoincrement())
  name        String
  code        String?  @unique
  description String?
  createdAt   DateTime @default(now())
  trips       Trip[]
}

model City {
  id        Int      @id @default(autoincrement())
  name      String
  state     String?
  country   String?  @default("BR")
  createdAt DateTime @default(now())
  trips     TripCity[]
}

model Vehicle {
  id        Int      @id @default(autoincrement())
  plate     String?  @unique
  model     String?
  notes     String?
  createdAt DateTime @default(now())
  trips     Trip[]
  expenses  VehicleExpense[]
}

model VehicleExpenseCategory {
  id          Int               @id @default(autoincrement())
  name        String            @unique
  description String?
  createdAt   DateTime          @default(now())
  expenses    VehicleExpense[]
}

model VehicleExpense {
  id         Int      @id @default(autoincrement())
  vehicleId  Int
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  date       DateTime
  categoryId Int?
  category   VehicleExpenseCategory? @relation(fields: [categoryId], references: [id])
  amount     Decimal   @default(0)
  currency   String?   @default("BRL")
  odometer   Decimal?
  workerId   Int?
  worker     Worker?  @relation(fields: [workerId], references: [id])
  receiptUrl String?
  notes      String?
  createdAt  DateTime  @default(now())

  @@index([vehicleId, workerId, categoryId])
}

model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TripCity {
  id          Int       @id @default(autoincrement())
  tripId      Int
  trip        Trip      @relation(fields: [tripId], references: [id])
  cityId      Int
  city        City      @relation(fields: [cityId], references: [id])
  clients     String[]  @default([])
  prices      Decimal[] @default([])
  information String[]  @default([])
  notes       String?
  createdAt   DateTime  @default(now())

  @@index([tripId, cityId])
}

model Trip {
  id                   Int      @id @default(autoincrement())
  vehicleId            Int?
  vehicle              Vehicle? @relation(fields: [vehicleId], references: [id])
  date                 DateTime // Data de início da viagem
  serviceTypeId        Int
  serviceType          ServiceType @relation(fields: [serviceTypeId], references: [id])
  mealExpense          Decimal? @default(0)
  fuelExpense          Decimal? @default(0)
  fuelInfo             String?
  extraExpense         Decimal? @default(0)
  extraInfo            String?
  kmDriven             Decimal? @default(0)
  costPerKm            Decimal? @default(0)
  profitPerKm          Decimal? @default(0)
  avgConsumption       Decimal?
  remainingAutonomy    Decimal?
  completed            Boolean   @default(false)
  endDate              DateTime?
  travelers            Worker[]  @relation("TravelerTrip")
  drivers              Worker[]  @relation("DriverTrip")
  note                 String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tripCities           TripCity[]
}
