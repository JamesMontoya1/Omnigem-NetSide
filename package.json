{
  "name": "plantoes-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:backend": "dotenv -- npm --prefix backend run start:dev",
    "dev:frontend": "dotenv -- npm --prefix frontend run dev",
    "dev:frontend:webpack": "dotenv -- npm --prefix frontend run dev:webpack",
    "dev": "dotenv -- concurrently \"npm:dev:backend\" \"npm:dev:frontend:webpack\"",
    "build:backend": "dotenv -- npm --prefix backend run build",
    "build:frontend": "dotenv -- npm --prefix frontend run build",
    "build": "dotenv -- concurrently \"npm:build:backend\" \"npm:build:frontend\"",
    "start:all": "npm run build && npm start",
    "start": "dotenv -- concurrently \"npm --prefix backend run start\" \"npm --prefix frontend run start\"",
    "prisma:generate": "dotenv -- prisma generate --schema=prisma/schema.prisma && npm run seed",
    "prisma:migrate": "dotenv -- prisma migrate dev --schema=prisma/schema.prisma && npm run seed",
    "seed": "dotenv -- npm --prefix backend run seed",
    "tunnel": "powershell -ExecutionPolicy Bypass -File scripts/tunnel.ps1"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "6.18.0"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^6.18.0",
    "dotenv": "^17.3.1",
    "pg": "^8.19.0"
  },
  "overrides": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
